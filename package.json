{
  "name": "@chub-ai/stage-template",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "runner": "vite",
    "dev:example": "VITE_EXAMPLE=$EXAMPLE vite",
    "build": "tsc && vite build",
    "build:headless": "vite build --mode headless",
    "test:smoke": "bun scripts/run-stage.mjs --all scenarios/*.smoke.json",
    "build:example": "tsc && node scripts/build-example.mjs",
    "build:examples": "tsc && node scripts/build-all-examples.mjs",
    "deploy:example": "node scripts/deploy-example.mjs",
    "build:delegator": "tsc && node scripts/build-delegator.mjs",
    "deploy:delegator": "node scripts/deploy-delegator.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@chub-ai/stages-ts": "^0.3.7",
    "@typescript-eslint/parser": "^7.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite-plugin-dts": "^3.9.1",
    "d3-weighted-voronoi": "^1.1.3"
  },
  "engines": {
    "node": "21.7.1"
  },
  "devDependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^29.1.1",
    "sass": "^1.72.0",
    "three": "^0.184.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "peerDependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "three": "^0.184.0",
    "@xenova/transformers": "^2.17.2"
  },
  "peerDependenciesMeta": {
    "@react-three/drei": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "@xenova/transformers": {
      "optional": true
    }
  }
}

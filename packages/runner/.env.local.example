# Copy to .env.local (gitignored) and fill in your key.
# Loaded by the standalone runner server (packages/runner/src/server.ts)
# and by the Vite dev/build config (packages/runner/vite.config.ts).

# Path to an external stage repo to run instead of this factory's own
# src/. When set, the runner's "@stage" alias resolves to
# STAGE_PATH/src, and STAGE_PATH/node_modules is added to Vite's module
# resolution so the external stage's own dependencies are found.
# Leave unset to run this repo's own src/Stage.tsx.
# STAGE_PATH=/home/me/git/space-ship-simulator
# STAGE_PATH=../../../other-chub-stage

# Model spec: provider:model
# Known providers: openai, anthropic
# Unknown providers treated as an OpenAI-compatible base URL
DEFAULT_MODEL=openai:gpt-4o
# DEFAULT_MODEL=anthropic:claude-sonnet-4-20250514
# DEFAULT_MODEL=http://localhost:8080:llama-3

# Per-provider API keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: proxy for Chub API calls (for VPN/geo-block bypass)
# CHUB_PROXY=http://localhost:8888
# CHUB_PROXY=socks5://localhost:1080
